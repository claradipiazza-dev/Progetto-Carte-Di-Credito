<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	id="WebApp_ID" version="4.0">
	<display-name>DiPiazza</display-name>
	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
		<welcome-file>index.htm</welcome-file>
		<welcome-file>index.jsp</welcome-file>
		<welcome-file>default.html</welcome-file>
		<welcome-file>default.htm</welcome-file>
		<welcome-file>default.jsp</welcome-file>
	</welcome-file-list>

	<servlet>
		<servlet-name>Accesso</servlet-name>
		<servlet-class>controller.Accesso</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>Accesso</servlet-name>
		<url-pattern>/Accesso</url-pattern>
	</servlet-mapping>

	<servlet>
		<servlet-name>Registrazione</servlet-name>
		<servlet-class>controller.Registrazione</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>Registrazione</servlet-name>
		<url-pattern>/Registrazione</url-pattern>
	</servlet-mapping>

	<servlet>
		<servlet-name>Home</servlet-name>
		<servlet-class>controller.Home</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>Home</servlet-name>
		<url-pattern>/Home</url-pattern>
	</servlet-mapping>
	
	<jsp-config>
		<jsp-property-group>
			<url-pattern>/WEB-INF/view/amministratoreView.jsp</url-pattern>
			<el-ignored>false</el-ignored>
		</jsp-property-group>
		<jsp-property-group>
			<url-pattern>/WEB-INF/view/utenteView.jsp</url-pattern>
			<el-ignored>false</el-ignored>
		</jsp-property-group>
		<jsp-property-group>
			<url-pattern>/WEB-INF/view/registrazioneCompletata.jsp</url-pattern>
			<el-ignored>false</el-ignored>
		</jsp-property-group>
	</jsp-config>

	<error-page>
		<location>/WEB-INF/view/errore.jsp</location>
	</error-page>
</web-app>